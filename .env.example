# En local: file:./dev.db
# En production sur Railway: monter un Volume (ex. /data) et utiliser file:/data/prod.db
# pour que la base survive aux redéploiements.
DATABASE_URL="file:./dev.db"

# URL publique exacte du site (sans slash final). Utilisée pour générer des liens
# fiables (boutons Telegram, courriels) plutôt que de deviner depuis la requête,
# car Railway peut transmettre l'origine en http:// même si le site est en https.
SITE_URL="http://localhost:3000"

# Session
ADMIN_SESSION_SECRET="generate-a-long-random-string"

# Compte admin initial (utilisé seulement par le script de seed)
ADMIN_EMAIL="admin@primaphoto.studio"
ADMIN_PASSWORD="changeme123"

# Cloudinary (https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Telegram (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
# Chaîne secrète au choix, utilisée pour vérifier que le webhook vient bien de Telegram
TELEGRAM_WEBHOOK_SECRET=""
